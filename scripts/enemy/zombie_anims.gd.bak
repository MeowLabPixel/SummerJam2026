## ZombieAnims: single source of truth for all zombie animation names.
class_name ZombieAnims

# Locomotion
const IDLE           := "Zombie Idle"
const WALK_1         := "Walk zom va1"       # no trailing space
const WALK_2         := "Walk zombie va2"    # no trailing space
const WALK_NONBINARY := "Non binary walk"
const WALK_BACKWARD  := "Back ward"

# Melee attack and grab
const ATTACK_1     := "Zombie Attack 1"
const ATTACK_2     := "Zombie Attack 2"
const GRAB_REACH   := "Zombie Attempt Grab"
const GRAB_SUCCESS := "Zombie Grab success"
const GRAB_FAIL    := "Zombie Grab fail"
const GRAB_HOLD    := "Zombie Grab success_"  # looping hold — closest match visible

# Ranged zombie (water gun) — not visible in list yet, keeping as placeholder
const RANGE_IDLE  := "Zombie Idle"           # fallback to base idle until imported
const RANGE_SHOOT := "Zombie Idle"           # placeholder — update when imported

# Balloon zombie
const BALLOON_IDLE  := "Balloone Zombie Idle"
const BALLOON_THROW := "Balloone Zombie Idle" # placeholder — throw not visible in list

# Defeated
const DEAD      := "dEAD ZOMBIE Start up"
const DEAD_WALK := "dEAD ZOMBIE walk"

# Body and arm hit reactions
const HIT_BODY      := "HIT Body"
const HIT_LEFT_ARM  := "HIT Left arm"
const HIT_RIGHT_ARM := "HIT  Right Arm"      # two spaces — matches list exactly

# Head hit sequence
const HIT_HEAD_ACT1               := "HIT head act 1 - when get hit"
const HIT_HEAD_ACT2_STUN          := "HIT head act 2(Stun_idle)"   # no trailing space
const HIT_HEAD_ACT3_TAKEDOWN      := "HIT head act 3-take down"
const HIT_HEAD_ACT4_TAKEDOWN_IDLE := "HIT head act 4 (Take_down_idle)"
const HIT_HEAD_ACT5_GETUP         := "HIT head act 5 (get_up )"

# Left leg hit sequence
const HIT_LLEG_ACT1_SLIP          := "Hit Leg act 1 Slipping"      # no trailing space
const HIT_LLEG_ACT2_SLIP_IDLE     := "Hit Leg act 2 (Slipping_Ilde)" # no trailing dash
const HIT_LLEG_ACT3_TAKEDOWN      := "Hit Leg act 3 (Take_down)"   # no trailing space
const HIT_LLEG_ACT4_TAKEDOWN_IDLE := "Hit Leg act 4 (Take_down_idle)"
const HIT_LLEG_ACT5_GETUP         := "HIT Leg act 5 (get_up )"     # no trailing space

# Right leg — not visible in new list, keeping previous values as placeholders
const HIT_RLEG_ACT1_SLIP          := "Hit Leg act 1 Slipping"
const HIT_RLEG_ACT2_SLIP_IDLE     := "Hit Leg act 2 (Slipping_Ilde)"
const HIT_RLEG_ACT3_TAKEDOWN      := "Hit Leg act 3 (Take_down)"
const HIT_RLEG_ACT4_TAKEDOWN_IDLE := "Hit Leg act 4 (Take_down_idle)"
const HIT_RLEG_ACT5_GETUP         := "HIT Leg act 5 (get_up )"

# Helpers
static func random_walk() -> String:
	return WALK_1 if randf() < 0.5 else WALK_2

static func random_attack() -> String:
	return ATTACK_1 if randf() < 0.5 else ATTACK_2

static func hit_reaction(hit_zone: String) -> String:
	match hit_zone:
		"head":      return HIT_HEAD_ACT1
		"left_leg":  return HIT_LLEG_ACT1_SLIP
		"right_leg": return HIT_RLEG_ACT1_SLIP
		"foot":      return HIT_LLEG_ACT1_SLIP
		"right_arm": return HIT_RIGHT_ARM
		"left_arm":  return HIT_LEFT_ARM
		_:           return HIT_BODY

static func stun_idle(hit_zone: String) -> String:
	match hit_zone:
		"head":
			return HIT_HEAD_ACT2_STUN
		"left_leg", "foot": return HIT_LLEG_ACT2_SLIP_IDLE
		"right_leg":        return HIT_RLEG_ACT2_SLIP_IDLE
		_:                  return HIT_HEAD_ACT2_STUN

static func takedown_anim(hit_zone: String) -> String:
	match hit_zone:
		"left_leg", "foot": return HIT_LLEG_ACT3_TAKEDOWN
		"right_leg":        return HIT_RLEG_ACT3_TAKEDOWN
		_:                  return HIT_HEAD_ACT3_TAKEDOWN

static func takedown_idle(hit_zone: String) -> String:
	match hit_zone:
		"right_leg":        return HIT_RLEG_ACT4_TAKEDOWN_IDLE
		"left_leg", "foot": return HIT_LLEG_ACT4_TAKEDOWN_IDLE
		_:                  return HIT_HEAD_ACT4_TAKEDOWN_IDLE

static func get_up_anim(hit_zone: String) -> String:
	return HIT_RLEG_ACT5_GETUP if hit_zone == "right_leg" else HIT_LLEG_ACT5_GETUP
